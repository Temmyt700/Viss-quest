{
  "name": "vq-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "npm run build && drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "npm run build && drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "admin:promote": "tsx src/scripts/promote-admin.ts",
    "spins:reset-today": "tsx src/scripts/reset-spins.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.0",
    "better-auth": "^1.5.5",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
